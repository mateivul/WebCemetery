{
    "manifest_version": 2,
    "name": "WebCemetery",
    "version": "1.0.0",
    "description": "A cemetery for your abandoned tabs. Track, resurrect, and find peace for your dead web pages.",
    "author": "Matei",

    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-48.png",
            "48": "icons/icon-128.png"
        },
        "default_title": "WebCemetery - Bury a Tab"
    },

    "background": {
        "scripts": ["background/background.js"]
    },

    "permissions": ["tabs", "storage", "notifications", "<all_urls>"],

    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": true
    },

    "commands": {
        "_execute_browser_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+K"
            },
            "description": "Open WebCemetery popup"
        },
        "kill-current-tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+D"
            },
            "description": "Kill current tab immediately"
        }
    },

    "web-accessible_resources": ["icons/*.png", "dashboard/dashboard.html"],

    "browser_specific_settings": {
        "gecko": {
            "id": "webcemetery@example.com",
            "strict_min_version": "109.0"
        }
    }
}
