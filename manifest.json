{
    "manifest_version": 3,
    "name": "WebCemetery",
    "version": "1.0.0",
    "description": "A cemetery for your abandoned tabs. Track, resurrect, and find peace for your dead web pages.",
    "author": "Matei",

    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-48.png",
            "48": "icons/icon-128.png"
        },
        "default_title": "WebCemetery - Bury a Tab"
    },

    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },

    "permissions": ["tabs", "storage", "notifications"],

    "host_permissions": ["<all_urls>"],

    "options_page": "options/options.html",

    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+K",
                "mac": "Command+Shift+D"
            },
            "description": "Open WebCemetery popup"
        },
        "kill-current-tab": {
            "suggested_key": {
                "default": "Ctrl+Shift+D",
                "mac": "Command+Shift+D"
            },
            "description": "Kill current tab immediately"
        }
    },

    "web_accessible_resources": [
        {
            "resource": ["icons/*png", "dashboard/dashboard.html"],
            "mathces": ["<all_urls>"]
        }
    ]
}
